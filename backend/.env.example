PORT=3001

# Required Google Document AI processor settings.
GOOGLE_DOCUMENT_AI_PROJECT_ID=your-google-cloud-project-id
GOOGLE_DOCUMENT_AI_LOCATION=us
GOOGLE_DOCUMENT_AI_PROCESSOR_ID=your-document-ocr-processor-id

# Optional: pin a deployed processor version.
# GOOGLE_DOCUMENT_AI_PROCESSOR_VERSION=your-processor-version-id

# Authentication option 1 (recommended for local service-account credentials):
GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service-account.json

# Authentication option 2 (useful in secret-managed deployments):
# GOOGLE_DOCUMENT_AI_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# Authentication option 3:
# GOOGLE_DOCUMENT_AI_API_KEY=your-api-key

# Authentication option 4 (ADC configured by gcloud or an attached cloud identity):
# GOOGLE_DOCUMENT_AI_USE_ADC=true

# Frontend uses the Vite /api proxy locally. For separate deployments, set:
# VITE_API_BASE_URL=https://your-backend.example.com
